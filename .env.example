# OpenAI API 配置
# 注意：请将此文件复制为 .env 并填入真实值
# 不要将包含真实凭证的 .env 文件提交到版本控制系统！

# OpenAI API 密钥（必填）
OPENAI_API_KEY=your-api-key-here

# OpenAI API 基础 URL（可选，默认使用官方 API）
OPENAI_BASE_URL=https://api.openai.com/v1

# 数据库配置（可选）
DATABASE_URL=sqlite:///./data/lab_agent.db

# JWT 密钥（生产环境请使用强密钥）
SECRET_KEY=your-secret-key-change-this-in-production-please-use-a-strong-key

# JWT 访问令牌过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=1440
